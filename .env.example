# Spreetail Shared Expenses SMTP Configuration Example
# Copy this file to a new file named '.env' and fill in your details.

# To send emails using Gmail:
# 1. Host must be smtp.gmail.com
# 2. Port is typically 465 (SSL) or 587 (TLS)
# 3. For SMTP_PASS, you must generate a 16-character "App Password" from your Google Account
#    (Google Account -> Security -> 2-Step Verification -> App Passwords).

SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your-email@gmail.com
SMTP_PASS=xxxx-xxxx-xxxx-xxxx

# JWT secret key for secure sessions
JWT_SECRET=spreetail-secret-key-12345
PORT=3000
